# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Claude Model Configuration
CLAUDE_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=4000
TEMPERATURE=0.3

# Claude Prompt Configuration (Optional)
# Leave empty to use default prompts from prompts/ directory
# Or specify custom file paths for system and user prompts
# CLAUDE_SYSTEM_PROMPT_FILE=/path/to/custom/system_prompt.txt
# CLAUDE_USER_PROMPT_FILE=/path/to/custom/user_prompt_template.txt

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Use DEBUG for detailed logging, INFO for normal operation
LOG_LEVEL=INFO

# Jira Configuration (Optional - leave empty to disable Jira integration)
JIRA_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your_jira_api_token_here

# Jira Labels Configuration
# Default labels are always applied to test cases (comma-separated)
JIRA_DEFAULT_LABELS=automated,regression
# Required labels - user must select at least one (comma-separated)
JIRA_REQUIRED_LABELS=frontend,backend,api,database,integration

# Jira Fixed Fields Configuration
# Project key for test cases
JIRA_PROJECT_KEY=TEST
# Component configuration (JSON format)
JIRA_COMPONENT_ID=10201
JIRA_COMPONENT_NAME=IAA
# Custom field values
JIRA_CUSTOMFIELD_10107=10
JIRA_CUSTOMFIELD_10223=/Onboarding and Authentication
JIRA_CUSTOMFIELD_10247_ID=10122
JIRA_CUSTOMFIELD_10247_VALUE=Comp.int Test
JIRA_CUSTOMFIELD_10214_ID=10116
JIRA_CUSTOMFIELD_10214_VALUE=Cucumber
# Gherkin custom field ID (already configured but included here for reference)
JIRA_GHERKIN_FIELD=customfield_10215

# Test Plan Selection Configuration
# JQL query to fetch available test plans for selection
JIRA_TEST_PLAN_JQL=type = "Test Plan" AND summary ~ "IAA test plan" and labels in ("Onboarding+Authentication") order by created desc
# Test Plan custom field (stores array of test plan issue keys)
JIRA_TEST_PLAN_FIELD=customfield_10221
